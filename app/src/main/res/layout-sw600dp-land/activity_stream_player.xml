<?xml version="1.0" encoding="utf-8"?>
<!--
  Landscape stream player for ~1024x600 tablets (sw600dp-land).
  VIDEO: full-screen PlayerView (unchanged from portrait).
  AUDIO: left panel = artwork + track info, right panel = playback controls.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- ══ VIDEO surface ════════════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/videoSurface"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black"
        android:visibility="gone">

        <androidx.media3.ui.PlayerView
            android:id="@+id/playerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:use_controller="true"
            app:controller_layout_id="@layout/custom_player_controls"
            app:show_buffering="when_playing"
            app:resize_mode="fit"
            app:auto_show="true"
            app:hide_on_touch="false"
            app:show_timeout="0" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:indeterminateTint="@color/accent"
            android:visibility="gone" />
    </FrameLayout>

    <!-- ══ AUDIO panel — horizontal split ══════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/audioPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:background="@color/bg_dark"
        android:visibility="gone">

        <!-- Left: artwork + track info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="32dp"
            android:paddingTop="64dp"
            android:paddingBottom="24dp">

            <!-- Album art -->
            <TextView
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:gravity="center"
                android:text="&#127925;"
                android:textSize="72sp"
                android:background="@drawable/bg_album_art" />

            <TextView
                android:id="@+id/streamTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="20dp"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/streamDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/hint_color"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginTop="4dp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/accent"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginTop="8dp"
                android:text="@string/status_connecting" />

            <!-- Codec · Bitrate info line -->
            <TextView
                android:id="@+id/trackCodecInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/hint_color"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:gravity="center"
                android:layout_marginTop="6dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/stroke_color" />

        <!-- Right: transport controls (no video surface) -->
        <androidx.media3.ui.PlayerView
            android:id="@+id/audioControlsView"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/surface_dark"
            android:paddingTop="64dp"
            app:use_controller="true"
            app:show_buffering="never"
            app:surface_type="none"
            app:controller_layout_id="@layout/audio_controls"
            app:auto_show="true"
            app:hide_on_touch="false"
            app:show_timeout="0" />

    </LinearLayout>

    <!-- ══ Top overlay: back + title + PiP (always on top) ════════════════ -->
    <LinearLayout
        android:id="@+id/topControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingBottom="12dp"
        android:paddingTop="0dp"
        android:gravity="center_vertical"
        android:background="@drawable/gradient_top">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/btn_back_desc"
            app:tint="@color/white" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingHorizontal="8dp">

            <TextView
                android:id="@+id/videoTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/videoDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#AAFFFFFF"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnPip"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_pip"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/btn_pip_desc"
            app:tint="@color/white"
            android:visibility="gone" />
    </LinearLayout>

</FrameLayout>
